<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="Finanzuebersicht.Views.YearOverviewPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             Title="Jahresansicht">
    <VerticalStackLayout Padding="10" Spacing="15">
        <Label Text="Jahresansicht" FontSize="Large" FontAttributes="Bold" />
        <Label Text="{Binding Year, StringFormat='Jahr: {0}'}" FontSize="16" />

        <!-- Jahressumme -->
        <Border BackgroundColor="{StaticResource CardBackground}" StrokeShape="RoundRectangle 10" Padding="15">
            <Label Text="{Binding YearTotal, StringFormat='Jahressumme: {0:N2}€'}" FontSize="16" FontAttributes="Bold" />
        </Border>

        <!-- Kategorien nach Ausgaben sortiert -->
        <Label Text="Ausgaben nach Kategorien:" FontSize="14" FontAttributes="Bold" Margin="0,10,0,0" />
        <CollectionView ItemsSource="{Binding Categories}" SelectionMode="None">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border BackgroundColor="{StaticResource CardBackground}" StrokeShape="RoundRectangle 8" Padding="12" Margin="0,4">
                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                            <BoxView Grid.Column="0" WidthRequest="16" HeightRequest="16" BackgroundColor="{Binding Color}" CornerRadius="2" VerticalOptions="Center" />
                            <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                <Label Text="{Binding CategoryName}" FontSize="13" FontAttributes="Bold" />
                                <Label Text="{Binding Total, StringFormat='{0:N2}€'}" FontSize="11" TextColor="Gray" />
                            </VerticalStackLayout>
                            <Label Grid.Column="2" Text="{Binding Total, StringFormat='{0:P}'}" FontSize="12" FontAttributes="Bold" VerticalOptions="Center" TextColor="Gray" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </VerticalStackLayout>
</ContentPage>
