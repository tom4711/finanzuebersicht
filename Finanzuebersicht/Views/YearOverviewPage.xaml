<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="Finanzuebersicht.Views.YearOverviewPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.Maui;assembly=LiveChartsCore.SkiaSharpView.Maui"
             Title="Jahresansicht">
    <VerticalStackLayout Padding="10">
        <Label Text="Jahresansicht (Prototyp)" FontSize="Large" />
        <Label Text="{Binding Year}" />

        <Frame HeightRequest="220" BackgroundColor="{StaticResource CardBackground}">
            <lvc:PieChart Series="{Binding PieSeries}" />
        </Frame>

        <Frame HeightRequest="220" BackgroundColor="{StaticResource CardBackground}">
            <lvc:CartesianChart Series="{Binding BarSeries}" />
        </Frame>

    </VerticalStackLayout>
</ContentPage>
