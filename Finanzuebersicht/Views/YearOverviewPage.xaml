<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="Finanzuebersicht.Views.YearOverviewPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             Title="Jahresansicht">
    <VerticalStackLayout Padding="10" Spacing="10">
        <Label Text="Jahresansicht" FontSize="Large" FontAttributes="Bold" />
        <Label Text="{Binding Year, StringFormat='Jahr: {0}'}" FontSize="16" />

        <!-- Kategorieliste -->
        <Label Text="Kategorien nach Ausgaben:" FontSize="14" FontAttributes="Bold" />
        <CollectionView ItemsSource="{Binding Categories}" SelectionMode="None">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10" Padding="10">
                        <BoxView Grid.Column="0" WidthRequest="16" HeightRequest="16" BackgroundColor="{Binding Color}" CornerRadius="2" />
                        <Label Grid.Column="1" Text="{Binding CategoryName}" FontSize="12" VerticalTextAlignment="Center" />
                        <Label Grid.Column="2" Text="{Binding Total, StringFormat='{0:N2}€'}" FontSize="12" FontAttributes="Bold" VerticalTextAlignment="Center" TextColor="Gray" />
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </VerticalStackLayout>
</ContentPage>
