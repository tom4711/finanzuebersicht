<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Finanzuebersicht.ViewModels"
             xmlns:models="clr-namespace:Finanzuebersicht.Models"
             xmlns:recurring="clr-namespace:Finanzuebersicht.Application.UseCases.RecurringTransactions;assembly=Finanzuebersicht.Application"
             xmlns:conv="clr-namespace:Finanzuebersicht.Converters"
             xmlns:loc="clr-namespace:Finanzuebersicht.Extensions"
             xmlns:controls="clr-namespace:Finanzuebersicht.Controls"
             x:Class="Finanzuebersicht.Views.DashboardPage"
             x:DataType="vm:DashboardViewModel"
             Title="{loc:Translate Nav_Dashboard}"
             BackgroundColor="{AppThemeBinding Light={StaticResource PageBackground}, Dark={StaticResource PageBackgroundDark}}">

    <ContentPage.Resources>
        <Style x:Key="DashboardAnalyticsCard" TargetType="Border">
            <Setter Property="StrokeShape" Value="RoundRectangle 16" />
            <Setter Property="Stroke" Value="Transparent" />
            <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource CardBackground}, Dark={StaticResource CardBackgroundDark}}" />
            <Setter Property="Padding" Value="16" />
        </Style>
        <Style x:Key="DashboardSectionDivider" TargetType="BoxView">
            <Setter Property="HeightRequest" Value="1" />
            <Setter Property="Color" Value="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray900}}" />
            <Setter Property="Margin" Value="0,12" />
        </Style>
        <Style x:Key="DashboardKpiCard" TargetType="Border">
            <Setter Property="StrokeShape" Value="RoundRectangle 12" />
            <Setter Property="Stroke" Value="Transparent" />
            <Setter Property="Padding" Value="10,12" />
        </Style>
        <Style x:Key="DashboardCardToggle" TargetType="Border">
            <Setter Property="StrokeShape" Value="RoundRectangle 8" />
            <Setter Property="Stroke" Value="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray900}}" />
            <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=#F2F2F7, Dark=#3A3A3C}" />
            <Setter Property="Padding" Value="2" />
            <Setter Property="WidthRequest" Value="140" />
        </Style>
        <conv:BilanzColorConverter x:Key="BilanzColor" />
        <conv:DecimalCurrencyConverter x:Key="Currency" />
        <conv:BilanzDisplayConverter x:Key="BilanzDisplay" />
        <conv:ProzentToWidthConverter x:Key="ProzentToWidth" />
        <conv:CountToBoolConverter x:Key="CountToBool" />
        <conv:ToggleActiveColorConverter x:Key="ToggleActiveColor" />
        <conv:ToggleActiveTextColorConverter x:Key="ToggleActiveText" />
        <conv:BudgetProgressColorConverter x:Key="BudgetProgressColor" />
        <conv:InvertBoolConverter x:Key="InvertBool" />
        <conv:StringToBoolConverter x:Key="StringToBool" />
        <conv:TrendColorConverter x:Key="TrendColor" />
    </ContentPage.Resources>

    <RefreshView Command="{Binding LoadDashboardCommand}"
                 IsRefreshing="{Binding IsLoading}">
        <ScrollView>
            <VerticalStackLayout Spacing="16" Padding="16,8,16,24">

                <!-- Zone 1: Hero (offen, ohne Kartenrahmen) -->
                <VerticalStackLayout Spacing="16" IsVisible="{Binding ShowHeroSaldo}">
                    <VerticalStackLayout Spacing="2" HorizontalOptions="Center" Padding="0,8,0,0">
                        <Label Text="{Binding SummarySaldo, Converter={StaticResource Currency}}"
                               FontSize="38"
                               FontAttributes="Bold"
                               HorizontalTextAlignment="Center"
                               TextColor="{Binding SummarySaldo, Converter={StaticResource BilanzColor}}" />
                        <Label Text="{Binding SummarySaldoLabel}"
                               FontSize="13"
                               HorizontalTextAlignment="Center"
                               TextColor="{AppThemeBinding Light={StaticResource TextTertiary}, Dark={StaticResource Gray600}}" />
                    </VerticalStackLayout>
                </VerticalStackLayout>

                <!-- Dauerauftrag: schmale Zeile -->
                <Border StrokeShape="RoundRectangle 8"
                        Stroke="{StaticResource ReminderBannerBorder}"
                        BackgroundColor="{AppThemeBinding Light={StaticResource ReminderBannerBackground}, Dark={StaticResource ReminderBannerBackgroundDark}}"
                        Padding="12,8"
                        IsVisible="{Binding HasDueItems}"
                        SemanticProperties.Description="{Binding DueRecurringText}">
                    <VerticalStackLayout Spacing="8">
                        <Grid ColumnDefinitions="*, Auto, Auto" ColumnSpacing="6">
                            <Label Text="{Binding DueRecurringText}"
                                   FontSize="14"
                                   VerticalTextAlignment="Center"
                                   TextColor="{AppThemeBinding Light={StaticResource ReminderBannerText}, Dark={StaticResource ReminderBannerTextDark}}">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding NavigateToDauerauftraegeCommand}" />
                                </Label.GestureRecognizers>
                            </Label>
                            <Label Grid.Column="1"
                                   Text="{Binding DueDetailsChevron}"
                                   FontSize="13"
                                   VerticalTextAlignment="Center"
                                   TextColor="{AppThemeBinding Light={StaticResource ReminderBannerText}, Dark={StaticResource ReminderBannerTextDark}}"
                                   SemanticProperties.Hint="{loc:Translate A11y_DauerauftraegeBannerHint}">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding ToggleDueDetailsCommand}" />
                                </Label.GestureRecognizers>
                            </Label>
                            <Label Grid.Column="2" Text="›" FontSize="18" FontAttributes="Bold"
                                   VerticalTextAlignment="Center"
                                   AutomationProperties.IsInAccessibleTree="False"
                                   TextColor="{AppThemeBinding Light={StaticResource ReminderBannerText}, Dark={StaticResource ReminderBannerTextDark}}">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding NavigateToDauerauftraegeCommand}" />
                                </Label.GestureRecognizers>
                            </Label>
                        </Grid>
                        <VerticalStackLayout Spacing="10"
                                             IsVisible="{Binding ShowDueDetailsList}"
                                             BindableLayout.ItemsSource="{Binding DueRecurringItems}">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="recurring:DueRecurringItem">
                                    <VerticalStackLayout Spacing="8">
                                        <Label Text="{Binding Recurring.Titel}" FontSize="15" FontAttributes="Bold"
                                               TextColor="{AppThemeBinding Light={StaticResource ReminderBannerText}, Dark={StaticResource ReminderBannerTextDark}}" />
                                        <Label Text="{Binding Hint}" FontSize="13" Opacity="0.85"
                                               TextColor="{AppThemeBinding Light={StaticResource ReminderBannerText}, Dark={StaticResource ReminderBannerTextDark}}" />
                                        <Button Text="{loc:Translate Btn_Buchen}" FontSize="14" HeightRequest="44"
                                                HorizontalOptions="Fill"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:DashboardViewModel}}, Path=BookDueRecurringCommand}"
                                                CommandParameter="{Binding .}" />
                                        <Grid ColumnDefinitions="*, *" ColumnSpacing="8">
                                            <Button Grid.Column="0" Text="{loc:Translate Btn_TerminUeberspringen}"
                                                    FontSize="12" HeightRequest="44"
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:DashboardViewModel}}, Path=SkipDueRecurringCommand}"
                                                    CommandParameter="{Binding .}" />
                                            <Button Grid.Column="1" Text="{loc:Translate Btn_TerminVerschieben}"
                                                    FontSize="12" HeightRequest="44"
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:DashboardViewModel}}, Path=ShiftDueRecurringCommand}"
                                                    CommandParameter="{Binding .}" />
                                        </Grid>
                                    </VerticalStackLayout>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <controls:EmptyStateView IconImage="dashboard.png"
                                         IconAccessibilityDescription="{loc:Translate Nav_Dashboard}"
                                         Message="{loc:Translate Empty_NochKeineTransaktionen}"
                                         ActionText="{loc:Translate Btn_ZuTransaktionen}"
                                         ActionCommand="{Binding NavigateToTransaktionenCommand}"
                                         IsVisible="{Binding HasAnyData, Converter={StaticResource InvertBool}}" />

                <VerticalStackLayout Spacing="16" IsVisible="{Binding HasAnyData}">

                    <!-- Monatsnavigation -->
                    <Grid ColumnDefinitions="Auto, *, Auto" IsVisible="{Binding IsMonthView}">
                        <Button Grid.Column="0" Text="‹" FontSize="32"
                                BackgroundColor="Transparent"
                                TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"
                                Command="{Binding PreviousMonthCommand}"
                                SemanticProperties.Description="{loc:Translate A11y_VorherigerMonat}"
                                WidthRequest="44" Padding="0" />
                        <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center" VerticalOptions="Center">
                            <Label Text="{Binding MonatAnzeige}"
                                   FontSize="18" FontAttributes="Bold"
                                   HorizontalTextAlignment="Center" />
                            <Label Text="{loc:Translate Lbl_Prognose}" FontSize="11"
                                   TextColor="{AppThemeBinding Light={StaticResource TextTertiary}, Dark={StaticResource Gray600}}"
                                   HorizontalTextAlignment="Center"
                                   IsVisible="{Binding IstPrognose}" />
                        </VerticalStackLayout>
                        <Button Grid.Column="2" Text="›" FontSize="32"
                                BackgroundColor="Transparent"
                                TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"
                                Command="{Binding NextMonthCommand}"
                                SemanticProperties.Description="{loc:Translate A11y_NaechsterMonat}"
                                WidthRequest="44" Padding="0" />
                    </Grid>

                    <!-- Jahresnavigation -->
                    <Grid ColumnDefinitions="Auto, *, Auto" IsVisible="{Binding IsYearView}">
                        <Button Grid.Column="0" Text="‹" FontSize="32"
                                BackgroundColor="Transparent"
                                TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"
                                Command="{Binding PreviousYearCommand}"
                                SemanticProperties.Description="{loc:Translate A11y_VorherigesJahr}"
                                WidthRequest="44" Padding="0" />
                        <Label Grid.Column="1" Text="{Binding JahrAnzeige}"
                               FontSize="18" FontAttributes="Bold"
                               HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                        <Button Grid.Column="2" Text="›" FontSize="32"
                                BackgroundColor="Transparent"
                                TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"
                                Command="{Binding NextYearCommand}"
                                SemanticProperties.Description="{loc:Translate A11y_NaechstesJahr}"
                                WidthRequest="44" Padding="0" />
                    </Grid>

                    <!-- KPI-Kacheln -->
                    <Grid ColumnDefinitions="*, *, *" ColumnSpacing="8" IsVisible="{Binding ShowMonthKpis}">
                        <Border Grid.Column="0" Style="{StaticResource DashboardKpiCard}"
                                BackgroundColor="{AppThemeBinding Light=#E8F8ED, Dark=#1E2E24}">
                            <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                                <Label Text="↑" FontSize="14" HorizontalTextAlignment="Center"
                                       TextColor="{AppThemeBinding Light={StaticResource Einnahme}, Dark={StaticResource EinnahmeDark}}" />
                                <Label Text="{loc:Translate Lbl_Einnahmen}" FontSize="10" HorizontalTextAlignment="Center"
                                       TextColor="{AppThemeBinding Light={StaticResource Einnahme}, Dark={StaticResource EinnahmeDark}}" />
                                <Label Text="{Binding GesamtEinnahmen, Converter={StaticResource Currency}}"
                                       FontSize="14" FontAttributes="Bold" HorizontalTextAlignment="Center"
                                       TextColor="{AppThemeBinding Light={StaticResource Einnahme}, Dark={StaticResource EinnahmeDark}}" />
                            </VerticalStackLayout>
                        </Border>
                        <Border Grid.Column="1" Style="{StaticResource DashboardKpiCard}"
                                BackgroundColor="{AppThemeBinding Light=#FDECEA, Dark=#2E1E1E}">
                            <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                                <Label Text="↓" FontSize="14" HorizontalTextAlignment="Center"
                                       TextColor="{AppThemeBinding Light={StaticResource Ausgabe}, Dark={StaticResource AusgabeDark}}" />
                                <Label Text="{loc:Translate Lbl_Ausgaben}" FontSize="10" HorizontalTextAlignment="Center"
                                       TextColor="{AppThemeBinding Light={StaticResource Ausgabe}, Dark={StaticResource AusgabeDark}}" />
                                <Label Text="{Binding GesamtAusgaben, Converter={StaticResource Currency}}"
                                       FontSize="14" FontAttributes="Bold" HorizontalTextAlignment="Center"
                                       TextColor="{AppThemeBinding Light={StaticResource Ausgabe}, Dark={StaticResource AusgabeDark}}" />
                            </VerticalStackLayout>
                        </Border>
                        <Border Grid.Column="2" Style="{StaticResource DashboardKpiCard}"
                                BackgroundColor="{AppThemeBinding Light={StaticResource CardBackground}, Dark=#2C2C2E}">
                            <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                                <Label Text="=" FontSize="14" HorizontalTextAlignment="Center"
                                       TextColor="{AppThemeBinding Light={StaticResource TextTertiary}, Dark={StaticResource Gray600}}" />
                                <Label Text="{loc:Translate Lbl_Bilanz}" FontSize="10" HorizontalTextAlignment="Center"
                                       TextColor="{AppThemeBinding Light={StaticResource TextTertiary}, Dark={StaticResource Gray600}}" />
                                <Label Text="{Binding Bilanz, Converter={StaticResource BilanzDisplay}}"
                                       FontSize="14" FontAttributes="Bold" HorizontalTextAlignment="Center"
                                       TextColor="{Binding Bilanz, Converter={StaticResource BilanzColor}}" />
                            </VerticalStackLayout>
                        </Border>
                    </Grid>

                    <!-- Konto-Filter dezent -->
                    <controls:SelectionField ItemsSource="{Binding AvailableKonten}"
                                             SelectedItem="{Binding SelectedKontoFilterItem, Mode=TwoWay}"
                                             DisplayMemberPath="DisplayName"
                                             Placeholder="{loc:Translate Lbl_AlleKonten}"
                                             IsVisible="{Binding HasKontenUebersicht}" />

                    <!-- Kompakte Insight-Zeilen (optional, standardmäßig aus) -->
                    <VerticalStackLayout Spacing="8" IsVisible="{Binding ShowInsightRows}">
                        <controls:DashboardInsightRow Title="{loc:Translate Lbl_KontenUebersicht}"
                                                      Detail="{Binding KontenCompactSummary}"
                                                      TapCommand="{Binding ToggleAccountsSectionCommand}"
                                                      IsVisible="{Binding ShowKontenInsightRow}" />
                        <VerticalStackLayout Spacing="8" IsVisible="{Binding IsAccountsSectionExpanded}"
                                             Margin="0,0,0,4">
                            <VerticalStackLayout BindableLayout.ItemsSource="{Binding KontenUebersicht}" Spacing="8">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate x:DataType="vm:AccountOverviewItem">
                                        <Grid ColumnDefinitions="*, Auto" Padding="4,0">
                                            <Grid.GestureRecognizers>
                                                <TapGestureRecognizer
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:DashboardViewModel}}, Path=SelectKontoFromOverviewCommand}"
                                                    CommandParameter="{Binding .}" />
                                            </Grid.GestureRecognizers>
                                            <Label Text="{Binding Name}" FontSize="14" VerticalTextAlignment="Center" />
                                            <Label Grid.Column="1"
                                                   Text="{Binding Saldo, Converter={StaticResource Currency}}"
                                                   FontSize="14" FontAttributes="Bold"
                                                   TextColor="{Binding Saldo, Converter={StaticResource BilanzColor}}" />
                                        </Grid>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                        <controls:DashboardInsightRow Title="{loc:Translate Lbl_BudgetHinweise}"
                                                      Detail="{Binding BudgetInsightDetail}"
                                                      IsVisible="{Binding ShowBudgetInsightRow}" />
                        <controls:DashboardInsightRow Title="{loc:Translate Lbl_Cashflow30Tage}"
                                                      Detail="{Binding CashflowInsightDetail}"
                                                      TapCommand="{Binding NavigateToCashflowCommand}"
                                                      IsVisible="{Binding ShowCashflowInsightRow}" />
                    </VerticalStackLayout>

                    <!-- Zone 2: Eine Analytics-Karte -->
                    <Border Style="{StaticResource DashboardAnalyticsCard}">
                        <VerticalStackLayout Spacing="4">

                            <!-- Kartenkopf: Titel + Monat/Jahr-Toggle -->
                            <Grid ColumnDefinitions="*, Auto" Margin="0,0,0,8">
                                <Label Text="{loc:Translate Lbl_Monat}"
                                       FontSize="18" FontAttributes="Bold"
                                       IsVisible="{Binding IsMonthView}"
                                       VerticalTextAlignment="Center" />
                                <Label Text="{loc:Translate Lbl_Jahr}"
                                       FontSize="18" FontAttributes="Bold"
                                       IsVisible="{Binding IsYearView}"
                                       VerticalTextAlignment="Center" />
                                <Border Grid.Column="1" Style="{StaticResource DashboardCardToggle}">
                                    <Grid ColumnDefinitions="*, *" ColumnSpacing="2">
                                        <Border Grid.Column="0" StrokeShape="RoundRectangle 6" Stroke="Transparent"
                                                BackgroundColor="{Binding IsMonthView, Converter={StaticResource ToggleActiveColor}}"
                                                Padding="6,4">
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer Command="{Binding ZeigeMonateCommand}" />
                                            </Border.GestureRecognizers>
                                            <Label Text="{loc:Translate Lbl_Monat}" HorizontalTextAlignment="Center"
                                                   FontSize="12" FontAttributes="Bold"
                                                   TextColor="{Binding IsMonthView, Converter={StaticResource ToggleActiveText}}" />
                                        </Border>
                                        <Border Grid.Column="1" StrokeShape="RoundRectangle 6" Stroke="Transparent"
                                                BackgroundColor="{Binding IsYearView, Converter={StaticResource ToggleActiveColor}}"
                                                Padding="6,4">
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer Command="{Binding ZeigeJahrCommand}" />
                                            </Border.GestureRecognizers>
                                            <Label Text="{loc:Translate Lbl_Jahr}" HorizontalTextAlignment="Center"
                                                   FontSize="12" FontAttributes="Bold"
                                                   TextColor="{Binding IsYearView, Converter={StaticResource ToggleActiveText}}" />
                                        </Border>
                                    </Grid>
                                </Border>
                            </Grid>

                            <!-- Monatsinhalt -->
                            <VerticalStackLayout Spacing="4" IsVisible="{Binding ShowMonthView}">

                                <!-- Budget-Balken -->
                                <VerticalStackLayout Spacing="10" IsVisible="{Binding HasBudgetHinweise}" Margin="0,0,0,4">
                                    <VerticalStackLayout BindableLayout.ItemsSource="{Binding BudgetHinweise}" Spacing="10">
                                        <BindableLayout.ItemTemplate>
                                            <DataTemplate x:DataType="models:BudgetHintSummary">
                                                <VerticalStackLayout Spacing="6">
                                                    <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="8">
                                                        <Label Grid.Column="0" Text="{Binding Icon}" FontSize="15" VerticalTextAlignment="Center" />
                                                        <Label Grid.Column="1" Text="{Binding CategoryName}" FontSize="14" VerticalTextAlignment="Center" />
                                                        <HorizontalStackLayout Grid.Column="2" Spacing="4">
                                                            <Label Text="{Binding Verbrauch, Converter={StaticResource Currency}}"
                                                                   FontSize="12" FontAttributes="Bold" />
                                                            <Label Text="/" FontSize="12"
                                                                   TextColor="{AppThemeBinding Light={StaticResource TextTertiary}, Dark={StaticResource Gray600}}" />
                                                            <Label Text="{Binding BudgetBetrag, Converter={StaticResource Currency}}"
                                                                   FontSize="12"
                                                                   TextColor="{AppThemeBinding Light={StaticResource TextTertiary}, Dark={StaticResource Gray600}}" />
                                                        </HorizontalStackLayout>
                                                    </Grid>
                                                    <ProgressBar HeightRequest="8"
                                                        Progress="{Binding VerbrauchProzent, Converter={StaticResource ProzentToWidth}}"
                                                        ProgressColor="{Binding IstAusgeschoepft, Converter={StaticResource BudgetProgressColor}}"
                                                        BackgroundColor="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray900}}" />
                                                </VerticalStackLayout>
                                            </DataTemplate>
                                        </BindableLayout.ItemTemplate>
                                    </VerticalStackLayout>
                                    <BoxView Style="{StaticResource DashboardSectionDivider}"
                                             IsVisible="{Binding KategorieAusgaben, Converter={StaticResource CountToBool}}" />
                                </VerticalStackLayout>

                                <!-- Ausgaben: Donut + Liste nebeneinander -->
                                <VerticalStackLayout Spacing="8"
                                                     IsVisible="{Binding KategorieAusgaben, Converter={StaticResource CountToBool}}">
                                    <Label Text="{loc:Translate Lbl_AusgabenNachKategorie}"
                                           FontSize="15" FontAttributes="Bold"
                                           SemanticProperties.HeadingLevel="Level2" />
                                    <Grid ColumnDefinitions="120, *" ColumnSpacing="12">
                                        <GraphicsView x:Name="MonthDonutChart"
                                                      WidthRequest="120"
                                                      HeightRequest="120"
                                                      VerticalOptions="Start"
                                                      HorizontalOptions="Center"
                                                      SemanticProperties.Description="{Binding MonthDonutAccessibilitySummary}" />
                                        <VerticalStackLayout Grid.Column="1"
                                                             BindableLayout.ItemsSource="{Binding KategorieAusgaben}"
                                                             Spacing="6"
                                                             VerticalOptions="Center">
                                            <BindableLayout.ItemTemplate>
                                                <DataTemplate x:DataType="models:CategorySummary">
                                                    <Grid ColumnDefinitions="10, Auto, *, Auto, Auto"
                                                          ColumnSpacing="6"
                                                          Padding="0,2">
                                                        <Border Grid.Column="0"
                                                                WidthRequest="8"
                                                                HeightRequest="8"
                                                                StrokeShape="RoundRectangle 4"
                                                                Stroke="Transparent"
                                                                BackgroundColor="{Binding Color}"
                                                                VerticalOptions="Center" />
                                                        <Label Grid.Column="1"
                                                               Text="{Binding Icon}"
                                                               FontSize="13"
                                                               VerticalTextAlignment="Center" />
                                                        <Label Grid.Column="2"
                                                               Text="{Binding CategoryName}"
                                                               FontSize="13"
                                                               LineBreakMode="TailTruncation"
                                                               VerticalTextAlignment="Center" />
                                                        <Label Grid.Column="3"
                                                               Text="{Binding Total, Converter={StaticResource Currency}}"
                                                               FontSize="12"
                                                               FontAttributes="Bold"
                                                               HorizontalTextAlignment="End"
                                                               TextColor="{AppThemeBinding Light={StaticResource Ausgabe}, Dark={StaticResource AusgabeDark}}"
                                                               VerticalTextAlignment="Center" />
                                                        <Label Grid.Column="4"
                                                               Text="{Binding PercentageDisplay}"
                                                               FontSize="12"
                                                               WidthRequest="44"
                                                               HorizontalTextAlignment="End"
                                                               TextColor="{AppThemeBinding Light={StaticResource TextTertiary}, Dark={StaticResource Gray600}}"
                                                               VerticalTextAlignment="Center" />
                                                    </Grid>
                                                </DataTemplate>
                                            </BindableLayout.ItemTemplate>
                                        </VerticalStackLayout>
                                    </Grid>
                                </VerticalStackLayout>

                                <BoxView Style="{StaticResource DashboardSectionDivider}"
                                         IsVisible="{Binding KategorieEinnahmen, Converter={StaticResource CountToBool}}" />

                                <!-- Einnahmen: eingeklappte Zeile -->
                                <Border StrokeShape="RoundRectangle 8" Stroke="Transparent"
                                        BackgroundColor="{AppThemeBinding Light=#F2F2F7, Dark=#3A3A3C}"
                                        Padding="12,10"
                                        IsVisible="{Binding KategorieEinnahmen, Converter={StaticResource CountToBool}}">
                                    <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="8">
                                        <Grid.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding ToggleMonthIncomeSectionCommand}" />
                                        </Grid.GestureRecognizers>
                                        <Label Text="{Binding MonthIncomeSectionChevron}"
                                               FontSize="12"
                                               VerticalTextAlignment="Center"
                                               TextColor="{AppThemeBinding Light={StaticResource TextTertiary}, Dark={StaticResource Gray600}}" />
                                        <Label Grid.Column="1"
                                               FontSize="14"
                                               VerticalTextAlignment="Center"
                                               TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}">
                                            <Label.FormattedText>
                                                <FormattedString>
                                                    <Span Text="{loc:Translate Lbl_EinnahmenNachKategorie}" />
                                                    <Span Text=" · " />
                                                    <Span Text="{Binding GesamtEinnahmen, Converter={StaticResource Currency}}"
                                                          FontAttributes="Bold"
                                                          TextColor="{AppThemeBinding Light={StaticResource Einnahme}, Dark={StaticResource EinnahmeDark}}" />
                                                </FormattedString>
                                            </Label.FormattedText>
                                        </Label>
                                        <Label Grid.Column="2" Text="›" FontSize="16"
                                               VerticalTextAlignment="Center"
                                               AutomationProperties.IsInAccessibleTree="False"
                                               TextColor="{AppThemeBinding Light={StaticResource TextTertiary}, Dark={StaticResource Gray600}}" />
                                    </Grid>
                                </Border>
                                <VerticalStackLayout IsVisible="{Binding IsMonthIncomeSectionExpanded}" Margin="4,0,0,0">
                                    <VerticalStackLayout BindableLayout.ItemsSource="{Binding KategorieEinnahmen}" Spacing="0">
                                        <BindableLayout.ItemTemplate>
                                            <DataTemplate x:DataType="models:CategorySummary">
                                                <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="8" Padding="0,6">
                                                    <Label Grid.Column="0" Text="{Binding Icon}" FontSize="14" />
                                                    <Label Grid.Column="1" Text="{Binding CategoryName}" FontSize="14" />
                                                    <Label Grid.Column="2"
                                                           Text="{Binding Total, Converter={StaticResource Currency}}"
                                                           FontSize="14" FontAttributes="Bold"
                                                           TextColor="{AppThemeBinding Light={StaticResource Einnahme}, Dark={StaticResource EinnahmeDark}}" />
                                                </Grid>
                                            </DataTemplate>
                                        </BindableLayout.ItemTemplate>
                                    </VerticalStackLayout>
                                </VerticalStackLayout>

                                <!-- Forecast -->
                                <Label Margin="0,12,0,0"
                                       HorizontalTextAlignment="Center"
                                       FontSize="14"
                                       IsVisible="{Binding HasForecast}">
                                    <Label.FormattedText>
                                        <FormattedString>
                                            <Span Text="{loc:Translate Lbl_ForecastNaechsterMonat}"
                                                  TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}" />
                                            <Span Text=" · " />
                                            <Span Text="{Binding ForecastTotal, Converter={StaticResource Currency}}"
                                                  FontAttributes="Bold"
                                                  TextColor="{AppThemeBinding Light={StaticResource Warning}, Dark={StaticResource WarningDark}}" />
                                        </FormattedString>
                                    </Label.FormattedText>
                                </Label>

                                <Label Text="{loc:Translate Empty_KeineDashboardDaten}"
                                       FontSize="14"
                                       TextColor="{AppThemeBinding Light={StaticResource TextTertiary}, Dark={StaticResource Gray600}}"
                                       HorizontalTextAlignment="Center"
                                       Margin="0,16,0,0"
                                       IsVisible="{Binding HasMonthData, Converter={StaticResource InvertBool}}" />
                            </VerticalStackLayout>

                            <!-- Jahresinhalt -->
                            <VerticalStackLayout Spacing="12" IsVisible="{Binding ShowYearView}">
                                <Border StrokeShape="RoundRectangle 10" Stroke="Transparent"
                                        BackgroundColor="{AppThemeBinding Light=#FDECEA, Dark=#2E1E1E}" Padding="12">
                                    <VerticalStackLayout Spacing="2">
                                        <Label Text="{loc:Translate Lbl_Jahresausgaben}" FontSize="11"
                                               TextColor="{AppThemeBinding Light={StaticResource Ausgabe}, Dark={StaticResource AusgabeDark}}" />
                                        <Label Text="{Binding JahrGesamtAusgaben, Converter={StaticResource Currency}}"
                                               FontSize="22" FontAttributes="Bold"
                                               TextColor="{AppThemeBinding Light={StaticResource Ausgabe}, Dark={StaticResource AusgabeDark}}" />
                                    </VerticalStackLayout>
                                </Border>

                                <VerticalStackLayout Spacing="8" IsVisible="{Binding HasYearData}">
                                    <Grid ColumnDefinitions="*, Auto">
                                        <Grid.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding ToggleYearMonthTrendCommand}" />
                                        </Grid.GestureRecognizers>
                                        <Label Text="{loc:Translate Lbl_AusgabenProMonat}"
                                               FontSize="15" FontAttributes="Bold" />
                                        <Label Grid.Column="1" Text="{Binding YearMonthTrendChevron}" FontSize="13"
                                               TextColor="{AppThemeBinding Light={StaticResource TextTertiary}, Dark={StaticResource Gray600}}" />
                                    </Grid>
                                    <GraphicsView x:Name="YearBarChart"
                                                  HeightRequest="140"
                                                  IsVisible="{Binding IsYearMonthTrendExpanded}"
                                                  SemanticProperties.Description="{Binding YearBarAccessibilitySummary}" />

                                    <BoxView Style="{StaticResource DashboardSectionDivider}" />

                                    <Grid ColumnDefinitions="*, Auto">
                                        <Grid.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding ToggleYearCategoriesCommand}" />
                                        </Grid.GestureRecognizers>
                                        <Label Text="{loc:Translate Lbl_AusgabenNachKategorie}"
                                               FontSize="15" FontAttributes="Bold" />
                                        <Label Grid.Column="1" Text="{Binding YearCategoriesChevron}" FontSize="13"
                                               TextColor="{AppThemeBinding Light={StaticResource TextTertiary}, Dark={StaticResource Gray600}}" />
                                    </Grid>
                                    <VerticalStackLayout Spacing="8" IsVisible="{Binding IsYearCategoriesExpanded}">
                                        <Grid ColumnDefinitions="120, *" ColumnSpacing="12">
                                            <GraphicsView x:Name="YearDonutChart"
                                                          WidthRequest="120"
                                                          HeightRequest="120"
                                                          HorizontalOptions="Center"
                                                          VerticalOptions="Start"
                                                          IsVisible="{Binding JahrKategorien, Converter={StaticResource CountToBool}}"
                                                          SemanticProperties.Description="{Binding YearDonutAccessibilitySummary}" />
                                            <VerticalStackLayout Grid.Column="1"
                                                                 BindableLayout.ItemsSource="{Binding JahrKategorien}"
                                                                 Spacing="6"
                                                                 VerticalOptions="Center">
                                                <BindableLayout.ItemTemplate>
                                                    <DataTemplate x:DataType="models:CategorySummary">
                                                        <Grid ColumnDefinitions="10, Auto, *, Auto, Auto"
                                                              ColumnSpacing="6"
                                                              Padding="0,2">
                                                            <Border Grid.Column="0"
                                                                    WidthRequest="8"
                                                                    HeightRequest="8"
                                                                    StrokeShape="RoundRectangle 4"
                                                                    Stroke="Transparent"
                                                                    BackgroundColor="{Binding Color}"
                                                                    VerticalOptions="Center" />
                                                            <Label Grid.Column="1" Text="{Binding Icon}" FontSize="13" VerticalTextAlignment="Center" />
                                                            <Label Grid.Column="2"
                                                                   Text="{Binding CategoryName}"
                                                                   FontSize="13"
                                                                   LineBreakMode="TailTruncation"
                                                                   VerticalTextAlignment="Center" />
                                                            <Label Grid.Column="3"
                                                                   Text="{Binding Total, Converter={StaticResource Currency}}"
                                                                   FontSize="12"
                                                                   FontAttributes="Bold"
                                                                   HorizontalTextAlignment="End"
                                                                   TextColor="{AppThemeBinding Light={StaticResource Ausgabe}, Dark={StaticResource AusgabeDark}}"
                                                                   VerticalTextAlignment="Center" />
                                                            <Label Grid.Column="4"
                                                                   Text="{Binding PercentageDisplay}"
                                                                   FontSize="12"
                                                                   WidthRequest="44"
                                                                   HorizontalTextAlignment="End"
                                                                   TextColor="{AppThemeBinding Light={StaticResource TextTertiary}, Dark={StaticResource Gray600}}"
                                                                   VerticalTextAlignment="Center" />
                                                        </Grid>
                                                    </DataTemplate>
                                                </BindableLayout.ItemTemplate>
                                            </VerticalStackLayout>
                                        </Grid>
                                    </VerticalStackLayout>
                                </VerticalStackLayout>

                                <Label Text="{loc:Translate Empty_KeineJahresDaten}"
                                       FontSize="14"
                                       TextColor="{AppThemeBinding Light={StaticResource TextTertiary}, Dark={StaticResource Gray600}}"
                                       HorizontalTextAlignment="Center"
                                       Margin="0,12,0,0"
                                       IsVisible="{Binding HasYearData, Converter={StaticResource InvertBool}}" />
                            </VerticalStackLayout>

                        </VerticalStackLayout>
                    </Border>

                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>
    </RefreshView>
</ContentPage>
