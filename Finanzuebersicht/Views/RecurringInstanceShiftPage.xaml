<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Finanzuebersicht.ViewModels"
             xmlns:loc="clr-namespace:Finanzuebersicht.Extensions"
             x:Class="Finanzuebersicht.Views.RecurringInstanceShiftPage"
             x:DataType="vm:RecurringInstanceShiftViewModel"
             Title="{loc:Translate Title_ShiftInstance}">

    <ScrollView Padding="16">
        <VerticalStackLayout Spacing="16">
            <Label Text="{loc:Translate Lbl_OriginalDatum}" FontSize="13" TextColor="Gray" />
            <Label Text="{Binding InstanceDate, StringFormat='{0:dd.MM.yyyy}'}" FontSize="18" />

            <Label Text="{loc:Translate Lbl_NeuesDatum}" FontSize="13" TextColor="Gray" />
            <DatePicker Date="{Binding NewDate}" Format="dd. MMMM yyyy" />

            <Label Text="{loc:Translate Hint_NotizOptional}" FontSize="13" TextColor="Gray" />
            <Entry Text="{Binding Note}" Placeholder="{loc:Translate Hint_NotizOptional}" />

            <Button Text="{loc:Translate Btn_Speichern}" Command="{Binding SaveCommand}" BackgroundColor="{DynamicResource Primary}" TextColor="White" />
            <Button Text="{loc:Translate Btn_Abbrechen}" Command="{Binding CancelCommand}" BackgroundColor="{DynamicResource Gray600}" TextColor="White" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
